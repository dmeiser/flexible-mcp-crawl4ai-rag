# ============================================================
# crawl4ai-mcp — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# -- PostgreSQL --
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpassword
POSTGRES_DB=ragdb
POSTGRES_URL=postgresql://raguser:ragpassword@rag-db:5432/ragdb

# -- Embedding --
# Options: ollama | openai
EMBEDDING_PROVIDER=ollama
EMBEDDING_DIM=768

# Ollama (used when EMBEDDING_PROVIDER=ollama)
OLLAMA_API_URL=http://ollama:11434/api/embeddings
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_MAX_RETRIES=3
OLLAMA_RETRY_DELAY_SECONDS=1.0

# OpenAI (used when EMBEDDING_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_EMBED_MODEL=text-embedding-3-small
# OPENAI_BASE_URL=   # Optional: override for Ollama OpenAI-compat endpoint

# -- Chunking --
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
# Options: paragraph | sentence | fixed
CHUNK_STRATEGY=paragraph
BATCH_SIZE=50

# -- RAG features --
USE_CONTEXTUAL_EMBEDDINGS=false
USE_HYBRID_SEARCH=false
USE_AGENTIC_RAG=false
USE_RERANKING=false

# -- Contextual Embedding LLM (only needed if USE_CONTEXTUAL_EMBEDDINGS=true) --
LLM_ENABLED=false
# LLM_API_KEY=
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL_NAME=anthropic/claude-3-haiku

# -- Server --
TRANSPORT=sse
HOST=0.0.0.0
PORT=8051
LOG_LEVEL=INFO
