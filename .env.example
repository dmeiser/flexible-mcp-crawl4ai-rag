# ============================================================
# crawl4ai-mcp — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# -- PostgreSQL --
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpassword
POSTGRES_DB=ragdb
POSTGRES_URL=postgresql://raguser:ragpassword@rag-db:5432/ragdb

# -- Embedding --
# Options: ollama | openai
EMBEDDING_PROVIDER=ollama
EMBEDDING_DIM=768

# Provider selection model:
# - Embeddings use explicit provider routing via EMBEDDING_PROVIDER.
# - LLM features below use explicit *_LLM_PROVIDER (openai | ollama).
#   *_BASE_URL still selects the endpoint for that provider.

# Provider-agnostic embedding settings (used by BOTH providers)
EMBEDDING_MODEL_NAME=nomic-embed-text

# Embedding endpoint (OpenAI-compatible):
# - Ollama:  EMBEDDING_BASE_URL=http://ollama:11434/v1
# - OpenAI:  EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_BASE_URL=http://ollama:11434/v1
# EMBEDDING_API_KEY=                 # optional for Ollama; required for OpenAI
EMBEDDING_MAX_RETRIES=3
EMBEDDING_RETRY_DELAY_SECONDS=1.0

# OpenAI example:
# EMBEDDING_API_KEY=sk-...
# EMBEDDING_MODEL_NAME=text-embedding-3-small
# EMBEDDING_BASE_URL=https://api.openai.com/v1

# -- Chunking --
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
# Options: paragraph | sentence | fixed
CHUNK_STRATEGY=paragraph
BATCH_SIZE=50

# -- RAG features --
USE_CONTEXTUAL_EMBEDDINGS=false
USE_HYBRID_SEARCH=false
USE_AGENTIC_RAG=false
USE_RERANKING=false
USE_WEB_SEARCH=false

# -- Default LLM (shared fallback for all LLM-powered features below) --
# Set these to avoid repeating credentials for every feature.
# Provider options: openai | ollama
# DEFAULT_LLM_PROVIDER=openai
#
# OpenAI example:
# DEFAULT_LLM_BASE_URL=https://api.openai.com/v1
# DEFAULT_LLM_API_KEY=sk-...
# DEFAULT_LLM_MODEL_NAME=gpt-4o-mini
# DEFAULT_LLM_MAX_RETRIES=3
# DEFAULT_LLM_RETRY_DELAY_SECONDS=1.0
#
# Ollama OpenAI-compatible example:
# DEFAULT_LLM_BASE_URL=http://ollama:11434/v1
# DEFAULT_LLM_MODEL_NAME=llama3.1:8b
# DEFAULT_LLM_MAX_RETRIES=3
# DEFAULT_LLM_RETRY_DELAY_SECONDS=1.0

# -- Per-feature LLM overrides (each falls back to DEFAULT_LLM_* if unset) --

# Contextual embeddings — used when USE_CONTEXTUAL_EMBEDDINGS=true
# CONTEXTUAL_LLM_PROVIDER=
# CONTEXTUAL_LLM_BASE_URL=
# CONTEXTUAL_LLM_API_KEY=
# CONTEXTUAL_LLM_MODEL_NAME=
# CONTEXTUAL_LLM_MAX_RETRIES=
# CONTEXTUAL_LLM_RETRY_DELAY_SECONDS=

# Agentic/shared LLM overrides.
# Used by LLM-based content filtering/extraction helpers and agentic-style
# features; USE_AGENTIC_RAG separately gates the search_code_examples tool.
# AGENTIC_LLM_PROVIDER=
# AGENTIC_LLM_BASE_URL=
# AGENTIC_LLM_API_KEY=
# AGENTIC_LLM_MODEL_NAME=
# AGENTIC_LLM_MAX_RETRIES=
# AGENTIC_LLM_RETRY_DELAY_SECONDS=

# Reranking — used when USE_RERANKING=true
# When RERANK_LLM_BASE_URL is unset, RERANK_LLM_MODEL_NAME is treated as a
# local sentence-transformers CrossEncoder model name.
# When RERANK_LLM_BASE_URL is set, reranking uses OpenAI-compatible chat scoring
# (works with OpenAI cloud or Ollama endpoints).
# RERANK_LLM_PROVIDER=
# RERANK_LLM_BASE_URL=
# RERANK_LLM_API_KEY=
# RERANK_LLM_MAX_RETRIES=
# RERANK_LLM_RETRY_DELAY_SECONDS=
RERANK_LLM_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2

# Web search — used when USE_WEB_SEARCH=true
# Provider options: openrouter
# WEB_SEARCH_PROVIDER=openrouter
# OpenRouter uses the current server-tool path:
# tools: [{"type": "openrouter:web_search", "parameters": {...}}]
# WEB_SEARCH_BASE_URL=https://openrouter.ai/api/v1
# WEB_SEARCH_API_KEY=
# WEB_SEARCH_MODEL_NAME=
# WEB_SEARCH_MAX_RETRIES=3
# WEB_SEARCH_RETRY_DELAY_SECONDS=1.0
# WEB_SEARCH_DEFAULT_ENGINE=auto
# WEB_SEARCH_DEFAULT_MAX_RESULTS=5

# Web search cache — used when WEB_SEARCH_CACHE_ENABLED=true
# Cached results are stored as short-lived crawl/recrawl leads and are not
# included in normal RAG retrieval by default.
# WEB_SEARCH_CACHE_ENABLED=false
# WEB_SEARCH_CACHE_TTL_HOURS=24
# WEB_SEARCH_CACHE_SOURCE=openrouter_web_search

# -- Server --
TRANSPORT=sse
HOST=0.0.0.0
PORT=8051
LOG_LEVEL=INFO
