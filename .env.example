# ============================================================
# crawl4ai-mcp — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# -- PostgreSQL --
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpassword
POSTGRES_DB=ragdb
POSTGRES_URL=postgresql://raguser:ragpassword@rag-db:5432/ragdb

# -- Embedding --
# Options: ollama | openai
EMBEDDING_PROVIDER=ollama
EMBEDDING_DIM=768

# Ollama (used when EMBEDDING_PROVIDER=ollama)
OLLAMA_API_URL=http://ollama:11434/api/embeddings
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_MAX_RETRIES=3
OLLAMA_RETRY_DELAY_SECONDS=1.0

# OpenAI (used when EMBEDDING_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_EMBED_MODEL=text-embedding-3-small
# OPENAI_BASE_URL=   # Optional: override for Ollama OpenAI-compat endpoint

# -- Chunking --
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
# Options: paragraph | sentence | fixed
CHUNK_STRATEGY=paragraph
BATCH_SIZE=50

# -- RAG features --
USE_CONTEXTUAL_EMBEDDINGS=false
USE_HYBRID_SEARCH=false
USE_AGENTIC_RAG=false
USE_RERANKING=false

# -- Default LLM (shared fallback for all LLM-powered features below) --
# Set these to avoid repeating credentials for every feature.
# DEFAULT_LLM_BASE_URL=https://openrouter.ai/api/v1
# DEFAULT_LLM_API_KEY=
# DEFAULT_LLM_MODEL_NAME=anthropic/claude-3-haiku

# -- Per-feature LLM overrides (each falls back to DEFAULT_LLM_* if unset) --

# Contextual embeddings — used when USE_CONTEXTUAL_EMBEDDINGS=true
# CONTEXTUAL_LLM_BASE_URL=
# CONTEXTUAL_LLM_API_KEY=
# CONTEXTUAL_LLM_MODEL_NAME=

# Hybrid search
# HYBRID_LLM_BASE_URL=
# HYBRID_LLM_API_KEY=
# HYBRID_LLM_MODEL_NAME=

# Agentic RAG — used when USE_AGENTIC_RAG=true
# AGENTIC_LLM_BASE_URL=
# AGENTIC_LLM_API_KEY=
# AGENTIC_LLM_MODEL_NAME=

# Reranking — used when USE_RERANKING=true
# When RERANK_LLM_BASE_URL is unset, RERANK_LLM_MODEL_NAME is treated as a
# local sentence-transformers CrossEncoder model name.
# RERANK_LLM_BASE_URL=
# RERANK_LLM_API_KEY=
RERANK_LLM_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2

# -- Server --
TRANSPORT=sse
HOST=0.0.0.0
PORT=8051
LOG_LEVEL=INFO
